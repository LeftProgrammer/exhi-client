{
  "name": "exhi-client",
  "version": "1.0.0",
  "description": "智慧展厅展示端 Runtime（白马项目首发）",
  "main": "out/main/index.js",
  "author": "exhi-team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "chcp 65001 >nul && electron-vite dev",
    "dev:online": "chcp 65001 >nul && set EXHI_HUB_URL=ws://localhost:18080&& electron-vite dev",
    "dev:baima": "chcp 65001 >nul && set EXHI_HUB_URL=ws://localhost:18080&& set EXHI_DEV_PACKAGE=baima-exhibition&& electron-vite dev",
    "dev:content": "node tools/content-dev/bin.mjs",
    "dev:status": "node tools/dev-helper/bin.mjs status",
    "dev:reset": "node tools/dev-helper/bin.mjs reset",
    "build": "chcp 65001 >nul && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "hub": "node tools/mock-hub/bin.mjs serve",
    "hub:send": "node tools/mock-hub/bin.mjs send",
    "hub:goto": "node tools/mock-hub/bin.mjs send cmd.gotoScene",
    "hub:reload": "node tools/mock-hub/bin.mjs send cmd.reload",
    "hub:volume": "node tools/mock-hub/bin.mjs send cmd.volume",
    "pkg:build": "node tools/pack-cli/bin.mjs build",
    "pkg:verify": "node tools/pack-cli/bin.mjs verify",
    "content-server": "node tools/content-server/bin.mjs",
    "release": "node tools/release-cli/bin.mjs publish",
    "guardian": "node guardian/guardian.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p runtime/renderer/tsconfig.json",
    "typecheck:packages": "npm run typecheck --workspaces --if-present",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:packages",
    "lint": "eslint . --ext .ts,.vue,.mjs,.cjs --cache",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"{runtime,packages/baima-exhibition/src,tools,guardian}/**/*.{ts,vue,json,css,scss,mjs}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@vueuse/core": "^11.3.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "fastify": "^5.1.0",
    "gsap": "^3.12.5",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "sass-embedded": "^1.81.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
