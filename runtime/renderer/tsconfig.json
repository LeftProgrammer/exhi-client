{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": "../..",
    "paths": {
      "@shared/*": ["runtime/shared/*"],
      "@renderer/*": ["runtime/renderer/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.d.ts",
    "../shared/**/*.ts"
  ]
}
